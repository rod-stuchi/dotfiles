# vim: set noexpandtab:

[include]
	# linux path for rod
	path = /disks/Vault/Secret_Files/user-gitconfig
	# macos path for rod
	path = /Volumes/VeraCrypt/Secret_Files/user-gitconfig


[core]
	editor = nvim
	pager = delta

[diff]
	tool = kdiff3
	colorMoved = default
	colorMovedWS = allow-indentation-change

[difftool "kdiff3"]
	cmd = QT_STYLE_OVERRIDE=kvantum kdiff3 "$LOCAL" "$REMOTE"

[log]
	date = relative

[pull]
	rebase = false
	ff = only

[push]
	# no more `git push -u origin <branch>`
	autoSetupRemote = true

[merge]
	# git 2.35+, clearer 3-way conflict markers
	conflictStyle = zdiff3

[rebase]
	# git 2.38+, auto-update stacked branch refs
	updateRefs = true

[branch]
	autoSetupMerge=false
	autoSetupRebase=never

[interactive]
	diffFilter = delta --color-only --features=interactive

[delta "interactive"]
	keep-plus-minus-markers = false

[delta]
	blame-palette                 = "#000000 #222222 #444444"
	commit-style                  = raw
	file-added-label              = 🟢 A
	file-modified-label           = 🟠 M
	file-removed-label            = 🔴 D
	file-renamed-label            = 🟣 R
	file-style                    = "#bababa bold #222222"
	hunk-header-style             = syntax
	hyperlinks                    = true
	line-numbers                  = true
	line-numbers-left-format      = "{nm:^4}⋮"
	line-numbers-left-style       = "blue"
	line-numbers-minus-style      = 88
	line-numbers-plus-style       = 28
	line-numbers-right-format     = "{np:^4}"
	line-numbers-right-style      = "blue"
	line-numbers-zero-style       = "#444444"
	max-line-distance             = 0.6
	max-line-length               = 512
	minus-emph-style              = normal "#901011"
	minus-empty-line-marker-style = normal "#3f0001"
	minus-non-emph-style          = normal "#3f0001"
	minus-style                   = normal "#3f0001"
	navigate                      = true
	pager                         = less -+S # -+S overrides the `S` (chop-long-lines) flag in the global LESS env so long lines wrap
	plus-emph-style               = syntax "#006000"
	plus-empty-line-marker-style  = normal "#002800"
	plus-non-emph-style           = syntax "#002800"
	plus-style                    = syntax "#002800"
	right-arrow                   = '⟶  '
	syntax-theme                  = "Monokai Extended"
	tabs                          = 4
	true-color                    = auto
	whitespace-error-style        = "#059be4" reverse # before: syntax "#006000"
	zero-style                    = dim syntax
	#blame-format = "{author:<18} ({commit:>7}) ┊{timestamp:^16}┊ "


#[format]
#	pretty = format:%C(auto,yellow)%h%C(auto,magenta)% G? %C(auto,blue)%>(12,trunc)%ad %C(auto,green)%<(16,trunc)%aN%C(auto,reset)%s%C(auto,red)% gD% D

[init]
	defaultBranch = master

[alias]
	tag-date = log --tags --simplify-by-decoration --pretty=\"format:%ci %d\"
	shorthash = rev-parse --short HEAD
	latest = !git branch --sort=authordate -vv | rg -v 'gone\\]'
	sw = !git switch $(git latest | fzf --no-sort --tac --nth=1 --accept-nth=1)
	cleanup-dry = !git branch -vv | rg -v '^[+*]' | gawk '/: gone\\]/ {print $1}' | xargs -L1 echo \">>> git branch -d\"
	cleanup = !git branch -vv | rg -v '^[+*]' | gawk '/: gone\\]/ {print $1}' | xargs -L1 git branch -d 

# macos path apple
[IncludeIf "gitdir:/Users/rods/dev/ns/**/.git"]
	path = /Volumes/VeraCrypt/Secret_Files/gitconfig-1

# macos path apple (for worktrees)
[IncludeIf "gitdir:/Users/rods/dev/ns/**/.git/worktrees/**"]
      path = /Volumes/VeraCrypt/Secret_Files/gitconfig-1

# macos path apple
[IncludeIf "gitdir:/Users/rods/dev/mks/**/.git"]
	path = /Volumes/VeraCrypt/Secret_Files/gitconfig-2

# macos path apple
[IncludeIf "gitdir:/Users/rods/dev/clmt/**/.git"]
	path = /Volumes/VeraCrypt/Secret_Files/gitconfig-3
